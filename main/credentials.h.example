/*
 * credentials.h.example
 *
 * Copy this file to `main/credentials.h`, fill in your real values,
 * and keep `main/credentials.h` out of version control (it's already
 * listed in .gitignore).
 */

#ifndef CREDENTIALS_H
#define CREDENTIALS_H

// Wi-Fi credentials
#define WIFI_SSID "Your_SSID_here"
#define WIFI_PASS "Your_WiFi_Password_here"

// MQTT / Broker credentials
#define MQTT_URI "your_URI"                     // Broker URI (no authentication in URI) Example forms: "user@192.0.2.1" or "mqtt://192.0.2.1:1883"
#define MQTT_USERNAME "your_username"           // MQTT broker username
#define MQTT_PASSWORD "your_password"           // MQTT broker password

#endif // CREDENTIALS_H
