# MQTT Broker Configuration
PROVISIONING_PASSWORD=CHANGE_ME
BOOTSTRAP_PASSWORD=CHANGE_ME
SUBSCRIBER_PASSWORD=CHANGE_ME

# Subscriber Configuration
MQTT_TOPICS=controller/telemetry

# Provisioner Configuration
TOKEN_TTL_HOURS=1

# Bootstrap HMAC secret — baked into device firmware
# Devices compute HMAC-SHA256(BOOTSTRAP_SECRET, device_id) to prove identity
# during provisioning. Compromise lets an attacker request tokens for any
# device_id — mitigated by the bootstrap ACL (provision topics only).
# Will need to implement OTA firmware update To handle leaks.
BOOTSTRAP_SECRET=CHANGE_ME_64_CHAR_HEX